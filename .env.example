# ============================================
# OpenTYME - Environment Variables Template
# ============================================
# Copy this file to .env and adjust values as needed.
# Defaults work for local development with Docker Compose.
# Do NOT commit your actual .env to version control.

# ============================================
# PUBLIC HOSTNAMES
# ============================================
# Local development defaults use localhost and *.localhost.
# Override these if you want to expose the stack under a custom LAN hostname.
APP_HOST=localhost
AUTH_HOST=auth.localhost
TRAEFIK_HOST=traefik.localhost
MAIL_HOST=mail.localhost
S3_HOST=s3.localhost
MCP_HOST=mcp.localhost
PUBLIC_PROTOCOL=http
PUBLIC_PORT=80

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=opentyme
POSTGRES_PASSWORD=password

# ============================================
# BACKEND CONFIGURATION
# ============================================
NODE_ENV=development
BACKEND_PORT=8000
BACKEND_SECRET_KEY=your-super-secret-key-here
JWT_SECRET=your-jwt-secret-here
DEBUG=true

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_PORT=3000
VITE_APP_ENVIRONMENT=development

# ============================================
# OBJECT STORAGE (SeaweedFS — S3-compatible)
# ============================================
# SeaweedFS is used locally and in Docker Compose.
# For Kubernetes, deploy SeaweedFS StatefulSet + Longhorn PVCs (see k8s/storage/).
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=password
# STORAGE_ENDPOINT and STORAGE_PORT are wired automatically by docker-compose.yml.
# Override here only when running the backend outside Docker:
# STORAGE_ENDPOINT=localhost
# STORAGE_PORT=8333
# STORAGE_USE_SSL=false

# ============================================
# EMAIL (MailHog for development)
# ============================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@opentyme.local

# ============================================
# AI / MCP SERVER (Optional - disabled by default)
# ============================================
AI_ENABLED=false

# Enable LLM-enhanced OCR (requires an API key)
# MCP_ENABLE_LLM=false
# MCP_OPENAI_API_KEY=
# MCP_OPENAI_BASE_URL=http://localhost:1234/v1
# MCP_OPENAI_MODEL=gpt-4o-mini
# MCP_PORT=8001

# ============================================
# ADDON / PLUGIN SYSTEM (Optional)
# ============================================
# GitHub token for private addon repos
# GITHUB_ADDON_TOKEN=
# GITLAB_ADDON_TOKEN=

# Comma-separated list of addons to install (overrides addons.config.json)
# OPENTYME_ADDONS=

# ============================================
# PROXY CONFIGURATION
# ============================================
NGINX_PORT=8888

# ============================================
# PRODUCTION OVERRIDES
# ============================================
# When deploying to production, change at minimum:
#   NODE_ENV=production
#   DEBUG=false
#   POSTGRES_PASSWORD=<strong-password>
#   BACKEND_SECRET_KEY=<random-64-char-string>
#   JWT_SECRET=<random-64-char-string>
#   KEYCLOAK_ADMIN_PASSWORD=<strong-password>
#   STORAGE_SECRET_KEY=<strong-password>
#   Configure SSL/TLS via Traefik (see traefik/traefik.yml)
#   Set up proper SMTP credentials for email delivery
